# SPDX-License-Identifier: Apache-2.0
PORT=3011

# Next.js
NEXT_TELEMETRY_DISABLED=1

# Server-to-server service URLs (NOT exposed to browser)
NATS_SERVER_URL=nats://nats:4222
ADMIN_SERVICE_URL=http://admin-service:3100
TMS_SERVER_URL=http://tms:3000

# Client-side config (safe - no credentials)
NEXT_PUBLIC_URL=http://localhost:3011
NEXT_PUBLIC_WS_URL=http://localhost:3011

# Alert pipeline (NATS subjects)
# NATS subject the BFF subscribes to for EVENT ADJUDICATOR results
# (relayed to the browser as the `eventAdjudicator` Socket.IO room).
ALERT_PRODUCER=investigation-service
# `global` (shared across all tenants) or `tenant` (per-tenant suffix).
ALERT_DESTINATION=global
# NATS subject the BFF subscribes to for TYPOLOGY PROCESSOR interdiction
# messages (relayed to the browser as the `interdiction-service-tp` room).
TP_INTERDICTION_PRODUCER=interdiction-service-tp
# `global` (shared across all tenants) or `tenant` (per-tenant suffix).
TP_INTERDICTION_DESTINATION=global

# Authentication
# Set AUTHENTICATED=true and fill in the lines below to enable Keycloak OIDC
AUTHENTICATED=false
#AUTH_SERVICE_URL=http://keycloak:8080/realms/tazama
#NEXTAUTH_SECRET=  # Required when AUTHENTICATED=true - generate: openssl rand -base64 32

# Test mode (Playwright e2e without a live stack)
TEST_MODE=false

# Condition type dropdown options
# Optional - built-in defaults are used when these are absent
CONDITION_TYPES=["non-overridable-block","overridable-block","override"]
EVENT_TYPES=["pacs.008.001.10","pacs.002.001.12","pain.001.001.11","pain.013.001.09"]
CONDITION_REASONS=["Sanction Screening Exception","Fraudulent Activity","False Positive Alerts", "Suspicion of Money Laundering","Violation of KYC/AML Requirements","Suspicion of Terrorist Financing","Tax Evasion Concerns","Regulatory Reporting Thresholds","Unusual Transaction Patterns","High-Risk Countries","Multiple Failed Login Attempts","Phishing or Account Takeover","Suspicious Beneficiaries","System Errors","Exceeding Limits","Legal Holds or Court Orders","Adverse media reports","Dormant or Inactive Accounts","Internal Bank Policies"]