# SPDX-License-Identifier: Apache-2.0
TAZAMA_VERSION=rc       # dev branch = rc | main branch = latest

# Docker CLI settings
COMPOSE_BAKE=false

# Cross-server
# Local-dev defaults. AWS deployments override these via env-extensions.tpl
# (applied by deploy-extensions.ps1 to both Server A and Server B).
SERVER_A_HOST=host.docker.internal
SERVER_B_HOST=localhost
SERVER_C_HOST=localhost

# --- Versions / branches ---

# TCS (connection-studio — single repo, backend + frontend subdirs)
TCS_BRANCH=dev

# TRS (rule-studio — separate backend/frontend branches)
TRS_BRANCH_BACKEND=dev
TRS_BRANCH_FRONTEND=dev

# CMS (case-management-system)
CMS_BRANCH=paysys/visualization

# DEMS/DEAPI (Server A pre-flight — match the branch in use on Server A)
DEMS_BRANCH=dev
DEAPI_BRANCH=dev

# --- Ports ---

# TCS
TCS_PORT=3010
TCS_FRONTEND_PORT=5173
SFTP_PORT=12222

# TRS
TRS_BACKEND_PORT=3005
TRS_FRONTEND_PORT=5174

# CMS
CMS_BACKEND_PORT=3090
CMS_FRONTEND_PORT=5175
VOILA_PORT=18866
COUCHDB_PORT=5984
FLOWABLE_PORT=8081

# Infrastructure
POSTGRESQL_CMS_PORT=15433
PGADMIN_PORT=5051           # must be explicit — compose fallback default is 5050 (Server A)
OPENSEARCH_PORT=9200

# DEMS/DEAPI (Server A — used by extensions launcher pre-flight)
DEMS_PORT=3002
DEAPI_PORT=3001
EVENT_SIDECAR_PORT=15000

# --- Shared credentials ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=unused


ELASTIC_STACK_VERSION=8.15
ES_MEM_LIMIT=1073741824
KB_MEM_LIMIT=1073741824
LS_MEM_LIMIT=1073741824

# TLS
NODE_TLS_REJECT_UNAUTHORIZED='0'