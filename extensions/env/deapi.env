# GLOBAL
NODE_ENV=dev
MAX_CPU=2
FUNCTION_NAME=data-enrichment-service
PORT=3001
SIZE=200mb

CORS_ORIGINS=http://${SERVER_B_HOST}:5173

POSTGRES_CONTAINER_NAME=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=unused
POSTGRES_DB=enrichment


CONFIGURATION_DATABASE_URL=postgresql://postgres:unused@postgres:5432/enrichment

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=unused
# Optional: Path to SSL/TLS certificate for secure DB connections
DB_CERT_PATH=
# Optional: Batch size for bulk operations (default: 1000)
BATCH_SIZE=1000

# REDIS
REDIS_CONTAINER_NAME=valkey
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_PASSWORD=redis-password
CACHE_TTL=7200

# NATS
NATS_CONTAINER_NAME=nats
SERVER_URL=nats://nats:4222
NATS_PORT=4222
NATS_HTTP_PORT=8222

STARTUP_TYPE=nats
PRODUCER_STREAM=enrichment.notification.response
CONSUMER_STREAM=enrichment.notification
STREAM_SUBJECT=enrichment.notification

ENCRYPTION_KEY=8fj29dkd82hs91kd93kd82hs91kd83ks
SALT_ROUNDS=10

# APM (Elastic APM)
APM_ACTIVE=false
APM_URL=http://localhost:8200
APM_SECRET_TOKEN=<change_me>
APM_SERVICE_NAME=data-enrichment-service

# AUTH
TAZAMA_AUTH_URL=http://auth:3020/v1/auth

AUTH_PUBLIC_KEY_PATH=/auth/test-public-key.pem

# SIDECAR
#SIDECAR_HOST=localhost:5000

# LOGGING
LOGSTASH_LEVEL=debug