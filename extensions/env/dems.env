# SPDX-License-Identifier: Apache-2.0
FUNCTION_NAME="event-monitoring-service"
NODE_ENV=dev
MAX_CPU=1
APP_PORT=3002
CORS_ORIGINS=http://${SERVER_B_HOST}:5173

# Database Configuration
CONFIGURATION_DATABASE_URL=postgresql://postgres:unused@postgres:5432/configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=unused
DB_NAME=configuration

DYNAMIC_HISTORY_DB_HOST=postgres
DYNAMIC_HISTORY_DB_PORT=5432
DYNAMIC_HISTORY_DB_NAME=raw_history
DYNAMIC_HISTORY_DB_USER=postgres
DYNAMIC_HISTORY_DB_PASSWORD=unused
DYNAMIC_HISTORY_DB_CERT_PATH=

EVENT_HISTORY_DB_HOST=postgres
EVENT_HISTORY_DB_PORT=5432
EVENT_HISTORY_DB_NAME=event_history
EVENT_HISTORY_DB_USER=postgres
EVENT_HISTORY_DB_PASSWORD=unused
EVENT_HISTORY_DB_CERT_PATH=

DB_MIN_CONNECTIONS=8
DB_MAX_CONNECTIONS=500

# Redis Configuration (Required)
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_PASSWORD=redis-password
TTL=3600

# NATS Configuration (frms-coe-startup-lib)
SERVER_URL=nats://nats:4222
STARTUP_TYPE=nats
PRODUCER_STREAM=dems.notification.response
CONSUMER_STREAM=config.notification


# Tazama Authentication
TAZAMA_AUTH_URL=http://auth:3020/v1/auth/login
AUTH_PUBLIC_KEY_PATH=/auth/test-public-key.pem
CERT_PATH_PUBLIC=/auth/test-public-key.pem