DATALAKEHOUSE_API_PORT=8282
PUBLIC_API_URL=http://${SERVER_C_HOST}:8282

# Query API Spark - sized for r5.2xlarge (8 vCPU, 64 GB)
# datalakehouse-api handles ad-hoc queries; lighter than the ETL orchestrator.
QUERY_API_SPARK_MASTER=local[2]
QUERY_API_SPARK_DRIVER_MEMORY=4g
QUERY_API_SPARK_DRIVER_MEMORY_OVERHEAD=1g
QUERY_API_SPARK_EXECUTOR_MEMORY=4g
QUERY_API_SPARK_EXECUTOR_MEMORY_OVERHEAD=1g
QUERY_API_SPARK_SQL_SHUFFLE_PARTITIONS=16
QUERY_API_SPARK_DEFAULT_PARALLELISM=16
QUERY_API_SPARK_NETWORK_TIMEOUT=300s
QUERY_API_SPARK_HEARTBEAT_INTERVAL=60s
QUERY_API_SPARK_ADVISORY_PARTITION_SIZE=32mb
QUERY_API_SPARK_MAX_PARTITION_BYTES=32mb