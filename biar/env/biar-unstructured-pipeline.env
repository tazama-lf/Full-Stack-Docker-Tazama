NODE_ENV=dev
FUNCTION_NAME=biar-processor

# CouchDB Configuration
# CouchDB is on Server B (extensions.tazama.internal). ${SERVER_B_HOST} must NOT be
# used here: env_file: values are not interpolated by Docker Compose.
COUCHDB_URL=http://simon:1234@extensions.tazama.internal:5984/cms-evidence

# Processing Services
# Docker service names - biar-tika, biar-solr, and biar-nifi are in the same tazama-biar project.
# ${SERVER_C_HOST} must NOT be used here: env_file: values are not interpolated by
# Docker Compose, and the EC2 SG blocks ports 9998, 8983, and 8081 for self-traffic.
TIKA_URL=http://biar-tika:9998
SOLR_URL=http://biar-solr:8983/solr/biar_docs
NIFI_URL=http://biar-nifi:8081/contentListener

# Cron Configuration - runs every 30 seconds
CRON_ENABLED=true
CRON_SCHEDULE=*/30 * * * * *

# Processing Limits
MAX_FILE_SIZE_MB=50
MAX_SOLR_CONTENT=1000000
TIKA_TIMEOUT=30000
NIFI_TIMEOUT=30000