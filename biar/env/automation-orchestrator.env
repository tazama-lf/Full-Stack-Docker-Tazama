AUTOMATION_ORCHESTRATOR_PORT=7619
NUM_WORKERS=1
# Docker service name for Ozone S3G.  Must NOT use ${SERVER_C_HOST} here because
# env_file: files are passed verbatim to containers — ${...} is not expanded.
# Using the EC2 hostname also routes through the ENI where port 9878 is not in the SG.
S3A_ENDPOINT=http://s3g:9878
S3A_ACCESS_KEY=tazama
S3A_SECRET_KEY=tazama
WAREHOUSE_ROOT=/opt/Tazama_Warehouse
APP_BASE_DIR=/app
OUT_DIR=/app/out

# Spark - sized for r5.2xlarge (8 vCPU, 64 GB)
# automation-orchestrator runs heavy PySpark ETL; allocate 4 cores and ~15 GB.
SPARK_MASTER=local[4]
SPARK_LOCAL_DIR=/tmp/spark
SPARK_DRIVER_MEMORY=12g
SPARK_DRIVER_MEMORY_OVERHEAD=3g
SPARK_DRIVER_MAX_RESULT_SIZE=4g
SPARK_EXECUTOR_MEMORY=12g
SPARK_EXECUTOR_MEMORY_OVERHEAD=3g
SPARK_SQL_SHUFFLE_PARTITIONS=32
SPARK_DEFAULT_PARALLELISM=32
SPARK_EXECUTOR_CORES=2
SPARK_DRIVER_CORES=2
SPARK_MEMORY_FRACTION=0.6
SPARK_MEMORY_STORAGE_FRACTION=0.3
