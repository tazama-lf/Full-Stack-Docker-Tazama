# SPDX-License-Identifier: Apache-2.0

# Docker CLI settings
COMPOSE_BAKE=false

# Cross-server
SERVER_A_HOST=localhost
SERVER_B_HOST=localhost
SERVER_C_HOST=localhost

# --- Ports ---
TIKA_PORT=9998
SOLR_PORT=8983
NIFI_PORT=8088
OZONE_SCM_PORT=9876
OZONE_OM_PORT=9874
OZONE_RECON_PORT=9888
OZONE_S3G_PORT=9878
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
KAFKA_CONNECT_PORT=8083
AUTOMATION_ORCHESTRATOR_PORT=7619
DATALAKEHOUSE_API_PORT=8282
JUPYTERHUB_PORT=8000

# --- Image version / branch ---
TAZAMA_VERSION=rc
BIAR_BRANCH=dev

# --- Warehouse ---
TAZAMA_WAREHOUSE_HOST_PATH=/opt/Warehouse

# --- Ozone / S3 ---
OZONE_REPLICATION_FACTOR=1
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET_NAME=tazama
# Ozone S3G endpoint — use Docker service name so all project containers use the
# Docker bridge network rather than routing through the EC2 ENI (which would hit
# the SG: port 9878 has no inbound rule on Server C).
S3A_ENDPOINT=http://ozone-s3g:9878
S3A_ACCESS_KEY=tazama
S3A_SECRET_KEY=tazama